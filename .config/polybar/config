[colors]
  ;background = #0d000000
  background = #0d000000
  background-alt = #60000000
  primary = #0dffffff
  secondary = #40666666
  focused = #fff
  alert = #bd2c40

[bar/top]
  bottom = false
  monitor = eDP-1

  background = ${colors.background}

  width = 100%
  height = 28

  border-size = 0
  border-color = #00000000

  padding-right = 2

  module-margin-left = 2  
  module-margin-right = 2 

  font-0 = FiraCode Regular:size=11;1
  font-1 = Hurmit Nerd Font:size=11;1

  modules-left = bspwm xwindow
  modules-center = date
  modules-right = xkeyboard pulseaudio brightness wlan battery

  wm-restack = bspwm

  scroll-up = bspwm-desknext
  scroll-down = bspwm-deskprev

[bar/top_monitor]
  bottom = false
  monitor = HDMI-1

  background = ${colors.background}

  width = 100%
  height = 28

  border-size = 0
  border-color = #00000000

  padding-right = 2

  module-margin-left = 2  
  module-margin-right = 2 

  font-0 = FiraCode Regular:size=11;1
  font-1 = Hurmit Nerd Font:size=11;1

  modules-left = bspwm xwindow
  modules-center = date
  modules-right = xkeyboard pulseaudio brightness wlan battery

  wm-restack = bspwm

  scroll-up = bspwm-desknext
  scroll-down = bspwm-deskprev

[module/xwindow]
  type = internal/xwindow
  label = %title:0:30:...%

[module/xkeyboard]
  type = internal/xkeyboard

  format = <label-layout> <label-indicator>
	format-prefix = 
	format-padding = 1

	label-layout = "  %layout%"
	label-indicator-on = %name%
	label-indicator-on-foreground = ${color.foreground}

  layout-icon-0 = br;Portuguese BR
  layout-icon-1 = us;English US

[module/bspwm]
  type = internal/bspwm

  pin-workspaces = true
  index-sort = true

  label-focused = %index%
  label-focused-background = ${colors.background-alt}
  label-focused-foreground= ${colors.focused}
  label-focused-padding = 3

  label-occupied = %index%
  label-occupied-background = ${colors.background}
  label-occupied-foreground= #99ffffff
  label-occupied-padding = 3

  label-urgent = %index%!
  label-urgent-background = ${colors.background}
  label-urgent-foreground= ${colors.alert}
  label-urgent-padding = 3

  label-empty = %index%
  label-empty-background = ${colors.background}
  label-empty-foreground = #99ffffff
  label-empty-padding = 3

[module/wlan]
  type = internal/network
  interface = wlp2s0
  interval = 5.0

  udspeed-minwidth = 0

  format-connected = <label-connected>
  label-connected = %{A1:kitty -e nmtui &:}直  %essid%%{A}
  label-connected-foreground = ${colors.focused}

  format-disconnected = <label-disconnected>
  label-disconnected = %{A1:kitty -e nmtui &:}睊  No connection%{A}
  label-disconnected-foreground = #80ffffff

[module/date]
  type = internal/date
  interval = 1

  date = " %a %b %d"
  time = "%H:%M:%S "

  format = <label>
  label = "  %time% %date%"

  padding-right = 4

  [module/pulseaudio]
  type = internal/pulseaudio
  use-ui-max = false

  format-volume = <ramp-volume> <label-volume>
  format-volume-padding = 1
  format-volume-prefix = %{T4}%{T-}
  format-volume-prefix-foreground = #fff

  label-volume = %percentage%%
  label-volume-foreground = #fff
  label-volume-padding = 1

  format-muted = <label-muted>
  format-muted-padding = 1
  format-muted-prefix = 婢 
  format-muted-prefix-foreground = #80ffffff

  label-muted = " Muted"
  label-muted-foreground = #80ffffff
  label-muted-padding = 1

  ramp-volume-0 = 
  ramp-volume-1 = 
  ramp-volume-2 = 

  click-right = pavucontrol&

[module/alsa]
  type = internal/alsa

  format-volume = "<label-volume>  <bar-volume>"
  label-volume = Volume
  label-volume-foreground = ${root.foreground}

  format-muted-prefix = "婢 "
  format-muted-foreground = ${colors.foreground-alt}
  label-muted = " 0%"

  bar-volume-width = 7.5
  bar-volume-foreground-0 = #0dc4c4c4
  bar-volume-foreground-1 = #40c4c4c4
  bar-volume-foreground-2 = #40c4c4c4
  bar-volume-foreground-3 = #40c4c4c4
  bar-volume-foreground-4 = #40c4c4c4
  bar-volume-foreground-5 = #fff
  bar-volume-foreground-6 = #fff
  bar-volume-gradient = false
  bar-volume-indicator = |
  bar-volume-indicator-font = 2
  bar-volume-fill = ─
  bar-volume-fill-font = 2
  bar-volume-empty = ─
  bar-volume-empty-font = 2
  bar-volume-empty-foreground = ${colors.foreground-alt}

[module/micro]
  type = internal/pulseaudio
  use-ui-max = true
  source = "@DEFAULT_SOURCE@"
  format-volume = <label-volume>
  format-muted = <label-muted>
  label-volume =   %percentage: 2%%
  label-muted =   %percentage: 2%%

[module/brightness]
  type = internal/backlight
  card = intel_backlight
  format = "<ramp>  <label>"
  label = %percentage: 2%%
  ramp-0 =  
  ramp-1 = 
  ramp-2 = 盛 
  enable-scroll = true

[module/battery]
  type = internal/battery

  full-at = 100

  battery = BAT0
  adapter = ADP1

  poll-interval = 5

  time-format = %H:%M

  format-charging = <animation-charging>  <label-charging>
  format-discharging = <ramp-capacity>  <label-discharging>

  label-charging = "%percentage%%"
  label-discharging = "%percentage%%"
  label-full = "  %percentage%%"

  ramp-capacity-0 = 
  ramp-capacity-1 = 
  ramp-capacity-2 = 
  ramp-capacity-3 = 
  ramp-capacity-4 = 
  ramp-capacity-5 = 

  ;bar-capacity-width = 10

  animation-charging-0 = 
  animation-charging-1 = 
  animation-charging-2 = 
  animation-charging-3 = 
  animation-charging-4 = 

  animation-charging-framerate = 750

[module/temperature]
  type = internal/temperature
  thermal-zone = 0
  warn-temperature = 60

  format = <ramp> <label>
  format-underline = #f50a4d
  format-warn = <ramp> <label-warn>
  format-warn-underline = ${self.format-underline}

  label = %temperature-c%
  label-warn = %temperature-c%
  label-warn-foreground = ${colors.secondary}

  ramp-0 = 
  ramp-1 = 
  ramp-2 = 
  ramp-foreground = ${colors.foreground-alt}

[settings]
  screenchange-reload = true
  ;compositing-background = xor
  ;compositing-background = screen
  ;compositing-foreground = source
  ;compositing-border = over
  pseudo-transparency = false 

[global/wm]
  margin-top = 1
  margin-bottom = 1

  ; vim:ft=dosini
